<Window x:Class="MufteevLanguage.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MufteevLanguage"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800" Icon="/res/school_logo.ico" FontFamily="Comic Sans MS">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="75"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>
        <Frame Grid.Row="0" Background="#E7FAF1"></Frame>
        <Image Source="/res/school_logo.png" HorizontalAlignment="Left"></Image>
        <TextBlock Text="Языковая школа" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center"></TextBlock>
        <Frame Grid.Row="1" Name="MainFrame"></Frame>
    </Grid>
</Window>